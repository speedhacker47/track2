{
  "refreshstateseconds": 20,
  "services": [
    {
      "name": "Call_01min",
      "intervalseconds": 20,
      "resourceurl": "https://portal.yonix.com.br/server/s_send.php"
    }
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  }
}
